{
  "expo": {
    "name": "FlockTrax",
    "slug": "flocktrax-mobile",
    "scheme": "flocktrax",
    "version": "1.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "../output/MC_Favicon2-transparent.png",
    "splash": {
      "image": "../output/MC_Favicon2-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2E8D5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.flocktrax.mobile",
      "buildNumber": "4",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.flocktrax.mobile",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "../output/MC_Favicon2-transparent.png",
        "backgroundColor": "#F2E8D5"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "4f065674-a17f-48d4-b1f6-66b21dba8a2f"
      }
    }
  }
}
